# Starship 프롬프트
eval "$(starship init zsh)"

setopt AUTO_CD

# 경로/명령 completion은 대소문자를 구분하지 않고 매칭
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

fpath+=$(brew --prefix)/share/zsh-completions

autoload -Uz compinit && compinit -i
source <(kubectl completion zsh)
[[ -s "$HOME/.gvm/scripts/gvm" ]] && source "$HOME/.gvm/scripts/gvm"

alias k='kubectl'
alias l='eza -abghHliS -s modified'
alias tree='eza --git-ignore --tree -I node_modules .'
alias npmr='npm run $(cat package.json | jq .scripts | jq -r "keys | .[]" | fzf)'
alias tm='tmux new-session -A -s main'
alias tailscale="/Applications/Tailscale.app/Contents/MacOS/Tailscale"
alias cca='claude --dangerously-skip-permissions'
alias coa='codex --yolo'
alias om='omx --madmax --high'
alias omo='opencode'

eval "$(direnv hook zsh)"

export SDKMAN_DIR=$(brew --prefix sdkman-cli)/libexec
[[ -s "${SDKMAN_DIR}/bin/sdkman-init.sh" ]] && source "${SDKMAN_DIR}/bin/sdkman-init.sh"

eval "$(fnm env --use-on-cd --shell zsh)"
eval "$(fzf --zsh)"
eval "$(ut completions zsh)"
eval "$(zoxide init zsh)"

source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source "${0:A:h}/cco.sh"
